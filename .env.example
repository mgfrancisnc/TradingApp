# Francis-Hayes Trading Bot — Environment Variables
# Copy this file to .env and fill in your actual keys
# NEVER commit .env to git — it is listed in .gitignore

# ── Alpaca Markets ────────────────────────────────────────
# Get keys at: https://alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_PAPER=true        # Keep true until ready for live trading

# ── No other API keys needed ──────────────────────────────
# yfinance and tradingview-screener are both free with no key required
