# Francis-Hayes Trading Bot — Environment Variables
# Copy this file to .env and fill in your actual keys
# NEVER commit .env to git — it is listed in .gitignore

# ── Alpaca Markets ────────────────────────────────────────
# Get keys at: https://alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_PAPER=true        # Keep true until ready for live trading

# ── Email Alerts ─────────────────────────────────────────
# Sends alerts for: assignments, ITM warnings, circuit breaker, scan complete
# Leave blank to disable alerts (bot runs fine without them)
#
# Gmail setup:
#   1. Enable 2-factor authentication on your Gmail account
#   2. Google Account → Security → App Passwords → create one for "Mail"
#   3. Use the 16-character app password below (NOT your Gmail login password)
#
ALERT_EMAIL_FROM=your_gmail@gmail.com
ALERT_EMAIL_TO=your_gmail@gmail.com     # Can be same address, or SMS gateway
ALERT_SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx # Gmail app password (16 chars)
ALERT_SMTP_HOST=smtp.gmail.com          # Default — change for other providers
ALERT_SMTP_PORT=587                     # Default — change for other providers

# ── No other API keys needed ──────────────────────────────
# yfinance and tradingview-screener are both free with no key required
